# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real tokens.

# Bearer token for WebSocket auth.
# If set, clients must connect with ?token=<value>.
# If unset, the server accepts any connection (local dev only).
SAGELAB_TOKEN=

# Hostname the server listens on. Do not use HOSTNAME — it collides with a shell builtin.
# Default: localhost
SAGELAB_HOST=localhost

# Port. Default: 3000
PORT=3000

# WebSocket path. Override for reverse proxies that rewrite paths.
# Default: /ws
SAGELAB_WS_PATH=/ws

# Mock runtime toggle.
# true (default): use simulateMockRun — no SDK required.
# false: require a real ClaudeCodeRuntime (returns RUN_FAILED until SDK spike is done).
SAGELAB_MOCK=true
